          borderRadius:"6px 6px 10px 10px",
          boxShadow:`0 4px 8px rgba(0,0,0,.2)` }}/>
      </div>

      {/* ── HIPS / PELVIS ── */}
      <div style={{
        position:"absolute", left:"50%", transform:"translateX(-50%)",
        top:258, width:120, height:50,
        background:`linear-gradient(180deg, ${skinD}, ${skinDark})`,
        borderRadius:"10px 10px 30px 30px",
        boxShadow:`4px 6px 16px rgba(0,0,0,.18), inset -4px -4px 12px ${skinDark}66`,
        zIndex:3,
      }}/>

      {/* ── LEFT LEG ── */}
      <div style={{ position:"absolute", left:"50%", marginLeft:-54, top:295, zIndex:2 }}>
