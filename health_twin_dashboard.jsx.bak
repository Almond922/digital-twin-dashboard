        {/* knee */}
        <div style={{ width:42, height:22, background:skinD, borderRadius:"50%",
          marginLeft:2, marginTop:-4, boxShadow:`0 2px 8px rgba(0,0,0,.15)` }}/>
        {/* shin */}
        <div style={{ width:38, height:90, background:`linear-gradient(178deg,${skin},${skinD})`,
          borderRadius:"12px 10px 10px 12px",
          boxShadow:`-2px 4px 12px rgba(0,0,0,.15)`, marginLeft:2 }}/>
        {/* foot */}
        <div style={{ width:44, height:20, background:`linear-gradient(90deg,${skinD},${skinDark})`,
          borderRadius:"8px 4px 4px 12px",
          boxShadow:`0 4px 10px rgba(0,0,0,.2)`, marginLeft:-2 }}/>
      </div>

      {/* ── RIGHT LEG ── */}
      <div style={{ position:"absolute", left:"50%", marginLeft:8, top:295, zIndex:2 }}>
        <div style={{ width:46, height:100, background:`linear-gradient(175deg,${skinD},${skin})`,
          borderRadius:"12px 16px 16px 12px",
          boxShadow:`2px 6px 14px rgba(0,0,0,.18), inset 4px 0 10px ${skinDark}44` }}/>
        <div style={{ width:42, height:22, background:skinD, borderRadius:"50%",
          marginTop:-4, boxShadow:`0 2px 8px rgba(0,0,0,.15)` }}/>
        <div style={{ width:38, height:90, background:`linear-gradient(178deg,${skinD},${skin})`,
          borderRadius:"10px 12px 12px 10px",
          boxShadow:`2px 4px 12px rgba(0,0,0,.15)`, marginLeft:2 }}/>
