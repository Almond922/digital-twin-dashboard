          boxShadow:`0 2px 6px rgba(0,0,0,.15)` }}/>
        {/* forearm */}
        <div style={{ width:22, height:70, background:`linear-gradient(175deg,${skin},${skinD})`,
          borderRadius:"10px 8px 8px 10px",
          boxShadow:`-2px 4px 10px rgba(0,0,0,.12)`,
          transform:"rotate(4deg)", marginLeft:2 }}/>
        {/* hand */}
        <div style={{ width:20, height:26, background:`linear-gradient(180deg,${skinD},${skinDark})`,
          borderRadius:"6px 6px 10px 10px", marginLeft:1,
          boxShadow:`0 4px 8px rgba(0,0,0,.2)` }}/>
      </div>

      {/* ── RIGHT ARM ── */}
      <div style={{ position:"absolute", right:12, top:108, zIndex:2 }}>
        <div style={{ width:26, height:80, background:`linear-gradient(170deg,${skinD},${skin})`,
          borderRadius:"10px 14px 14px 10px",
          boxShadow:`2px 4px 10px rgba(0,0,0,.15), inset 4px 0 8px ${skinDark}44`,
          transformOrigin:"top center", transform:"rotate(-8deg)" }}/>
        <div style={{ width:24, height:18, background:skinD, borderRadius:"50%",
          marginTop:-4, marginLeft:0, boxShadow:`0 2px 6px rgba(0,0,0,.15)` }}/>
        <div style={{ width:22, height:70, background:`linear-gradient(175deg,${skinD},${skin})`,
          borderRadius:"8px 10px 10px 8px",
          boxShadow:`2px 4px 10px rgba(0,0,0,.12)`,
