      <OrganDot id="llung"    label="L. Lung"      color="#42a5f5" stressed={stressed.lungs}  selected={selected} onSelect={onSelect} style={{ top:134, left:32 }}/>
      <OrganDot id="rlung"    label="R. Lung"      color="#29b6f6" stressed={stressed.lungs}  selected={selected} onSelect={onSelect} style={{ top:134, right:28 }}/>
      <OrganDot id="liver"    label="Liver"        color="#66bb6a" stressed={false}           selected={selected} onSelect={onSelect} style={{ top:188, right:30 }}/>
      <OrganDot id="stomach"  label="Stomach"      color="#ffa726" stressed={false}           selected={selected} onSelect={onSelect} style={{ top:192, left:"50%", marginLeft:-14 }}/>
      <OrganDot id="kidney_l" label="L. Kidney"    color="#ab47bc" stressed={false}           selected={selected} onSelect={onSelect} style={{ top:228, left:34 }}/>
      <OrganDot id="kidney_r" label="R. Kidney"    color="#ab47bc" stressed={false}           selected={selected} onSelect={onSelect} style={{ top:228, right:30 }}/>
      <OrganDot id="intestine"label="Intestine"    color="#26a69a" stressed={false}           selected={selected} onSelect={onSelect} style={{ top:262, left:"50%", transform:"translateX(-50%)" }}/>
    </div>
  );
}

function DigitalTwinLarge({ stress, selected, onSelect }) {
  const glow = '0 8px 30px rgba(0,229,255,0.12)';
  return (
    <div style={{ width:'100%', height:360, display:'flex', alignItems:'center', justifyContent:'center' }}>
      <div style={{ width:360, height:360, borderRadius:16, position:'relative', overflow:'hidden', boxShadow:glow }}>
        <svg viewBox="0 0 360 360" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="neonG" x1="0" x2="1"><stop offset="0%" stopColor="#00e5ff" stopOpacity="0.25"/><stop offset="100%" stopColor="#7c4dff" stopOpacity="0.15"/></linearGradient>
            <filter id="blur" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M20 0 L0 0 0 20" fill="none" stroke="#042033" strokeWidth="0.6"/>
            </pattern>
          </defs>

          {/* background grid */}
          <rect x="0" y="0" width="360" height="360" fill="#041224" />
          <rect x="0" y="0" width="360" height="360" fill="url(#grid)" opacity="0.6" />

          {/* hologram glow */}
          <g transform="translate(180,80)">
            <ellipse cx="0" cy="210" rx="90" ry="18" fill="#001826"/>
            <ellipse cx="0" cy="210" rx="70" ry="12" fill="#002a3a"/>
          </g>

          {/* simplified neon body */}
          <g transform="translate(0,6)" stroke="#00e5ff" strokeWidth="2" fill="none" strokeLinecap="round" strokeLinejoin="round" filter="url(#blur)">
            <path d="M180 40 C165 40,150 60,150 80 L150 120 C150 140,140 150,140 170 L140 220 C140 240,150 260,150 280 L145 305 C180 320,200 320,235 305 L230 280 C230 260,240 240,240 220 L240 170 C240 150,230 140,230 120 L230 80 C230 60,215 40,200 40"/>
          </g>

          {/* inner lines */}
          <g transform="translate(0,6)" stroke="#00a8d4" strokeWidth="1" fill="none" strokeLinecap="round" strokeLinejoin="round" opacity="0.7">
            <path d="M180 60 C170 60,160 75,160 90"/>
            <path d="M200 60 C210 60,220 75,220 90"/>
          </g>

          {/* heart icon with glow */}
          <g transform="translate(165,140)">
            <circle cx="15" cy="-10" r="16" fill="#ef5350" opacity="0.12"/>
            <path d="M12 -4 C8 0,5 0,5 -4 C5 -10,12 -12,12 -12 C12 -12,19 -10,19 -4 C19 0,16 0,12 -4 Z" fill="#ef5350" stroke="#ff6b6b" strokeWidth="1"/>
          </g>

          {/* right-side organ buttons */}
          <g transform="translate(290,60)">
            {['Heart','Lungs','Brain','Stomach','Liver','Kidneys'].map((t,i)=> (
              <g key={t} transform={`translate(0, ${i*44})`}>
                <rect x="-8" y="-12" width="68" height="28" rx="8" fill="#021825" stroke="#063447"/>
                <text x="24" y="6" fontSize="10" fill="#7fd7ff" fontWeight="600" textAnchor="middle">{t}</text>
              </g>
            ))}
          </g>
        </svg>
      </div>
    </div>
  );
}

